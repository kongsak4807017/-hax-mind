TELEGRAM_BOT_TOKEN=PUT_YOUR_BOT_TOKEN_HERE
# Optional comma-separated Telegram numeric user IDs.
# If empty, the bot allows all users who can reach the bot.
TELEGRAM_ALLOWED_USER_IDS=

# Optional OpenRouter setup for future HAX-Mind orchestration.
# Recommended free-router default:
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openrouter/free
OPENROUTER_APP_NAME=HAX-Mind
OPENROUTER_SITE_URL=

# Phase 2 PicoClaw worker bridge secret. Set the same value on the Windows brain
# and on the remote worker before sending heartbeats or claiming jobs.
PICOCLAW_SHARED_SECRET=replace_me_with_a_long_random_value

# Phase 2 PicoClaw / worker control plane. Set the same secret on the Windows
# brain and on the worker manually.
PICOCLAW_WORKER_SECRET=PUT_SHARED_SECRET_HERE
PICOCLAW_WORKER_ID=termux-main
